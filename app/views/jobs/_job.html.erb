<div id="<%= dom_id job %>">
  <div>
    <strong>Title:</strong>
    <%= job.title %>
  </div>

  <div>
    <strong>Company:</strong>
    <%= job.company %>
  </div>

  <div>
    <strong>Location:</strong>
    <%= job.location %>
  </div>

  <div>
    <strong>Salary:</strong>
    <%= job.salary %>
  </div>

  <div>
    <strong>Description:</strong>
    <%= job.description %>
  </div>

</div>
